# ── Google Cloud ───────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=genaiacademy-491713
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=True
MODEL=gemini-2.5-flash-lite

# ── AlloyDB ────────────────────────────────────────────────────
ALLOYDB_INSTANCE_URI=projects/genaiacademy-491713/locations/us-central1/clusters/til-cluster/instances/til-primary
DB_USER=postgres
DB_PASSWORD=your-password-here
DB_NAME=til_db

# ── Google Workspace MCP (google-workspace-mcp package) ────────
# Get these from GCP Console → APIs & Services → Credentials → Desktop App OAuth client
GOOGLE_WORKSPACE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_WORKSPACE_CLIENT_SECRET=GOCSPX-your-secret
# Get this by running: python workspace-mcp-service/get_refresh_token.py (one-time)
GOOGLE_WORKSPACE_REFRESH_TOKEN=your-refresh-token-here

# ── workspace-mcp server URL ───────────────────────────────────
# Local dev:      http://localhost:8080/mcp
# Cloud Run:      https://workspace-mcp-til-XXXX.us-central1.run.app/mcp  (set after deploy)
WORKSPACE_MCP_URL=http://localhost:8080/mcp

# ── Team ───────────────────────────────────────────────────────
TEAM_EMAILS=jesse@example.com,alex@example.com,sarah@example.com,miguel@example.com,dana@example.com
